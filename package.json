{
  "name": "pi-lazy-extensions",
  "version": "0.1.0",
  "description": "Lazy-load pi extensions on demand via a ToolSearch-style proxy tool",
  "type": "module",
  "license": "MIT",
  "author": "Nico Bailon",
  "keywords": [
    "pi-package",
    "pi",
    "lazy",
    "extension",
    "coding-agent",
    "tool-search"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "config.ts",
    "registry.ts",
    "proxy-modes.ts",
    "types.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:dead": "knip --no-gitignore"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "knip": "^6.7.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
